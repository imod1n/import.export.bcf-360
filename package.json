{
  "$schema": "node_modules/albatros/schema.json",
  "name": "i.m.import.export.bcf",
  "version": "1.0.1",
  "displayName": "Импорт и экспорт BCF",
  "description": "Просмотр, создание и редактирование замечаний в формате BCF",
  "main": "src/index.ts",
  "icon": "icons/logo.svg",
  "sdk": "^1.4.4",
  "apx": true,
  "repository": {
    "type": "git",
    "url": "https://github.com/imod1n/import.export.bcf-360"
  },
  "author": {
    "name": "Ivan M",
    "url": ""
  },
  "scripts": {
    "serve": "albatros-cli serve",
    "build": "albatros-cli build"
  },
  "devDependencies": {
    "albatros": "^1.4.2"
  },
  "dependencies": {
    "html-to-image": "^1.11.13",
    "jszip": "^3.10.1"
  },
  "albatros": {
    "actions": {
      "bcf_open": {
        "label": "Показать/скрыть панель BCF",
        "cmd": "showBcfPanelCmd",
        "icon": "assignment",
        "description": "Показать или скрыть панель BCF-замечаний",
        "flags": 128
      },
      "bcf_username": {
        "label": "Имя пользователя",
        "cmd": "setUsernameCmd",
        "icon": "person",
        "description": "Задать имя автора для замечаний и комментариев",
        "flags": 128
      },
      "bcf_new": {
        "label": "Создать новый файл BCF",
        "cmd": "bcfNewCmd",
        "icon": "note_add",
        "description": "Создать новый пустой BCF-файл",
        "flags": 128
      },
      "bcf_open_file": {
        "label": "Открыть BCF-файл...",
        "cmd": "bcfOpenFileCmd",
        "icon": "folder_open",
        "description": "Открыть существующий BCF-файл",
        "flags": 128
      }
    },
    "dynamics": {},
    "menu": [
      {
        "label": "Формат BCF",
        "submenu": [
          {
            "action": "bcf_new"
          },
          {
            "action": "bcf_open_file"
          },
          { "tag": "s" },
          {
            "action": "bcf_username"
          },
          { "tag": "s" },
          {
            "action": "bcf_open"
          }
        ]
      }
    ],
    "context": {},
    "pages": [
      {
        "tag": "bcf_tools",
        "label": "Формат BCF",
        "groups": [
          {
            "tag": "bcf_group",
            "label": "Замечания",
            "items": [
              {
                "tag": "b",
                "action": "bcf_new"
              },
              {
                "tag": "b",
                "action": "bcf_open_file"
              },
              { "tag": "s" },
              {
                "tag": "b",
                "action": "bcf_username"
              },
              { "tag": "s" },
              {
                "tag": "b",
                "action": "bcf_open"
              }
            ]
          }
        ]
      }
    ],
    "statusbar": {},
    "viewsContainers": {
      "bcfContainer": {
        "label": "Формат BCF",
        "icon": "assignment",
        "order": 100,
        "container": "bottom"
      }
    },
    "views": {
      "bcfView": {
        "label": "BCF",
        "type": "defined",
        "icon": "assignment",
        "container": "bcfContainer",
        "cmd": "mountBcfPanel",
        "expanded": true
      }
    },
    "rules": {},
    "properties": {},
    "storages": {},
    "editors": {},
    "broadcasts": {}
  }
}
